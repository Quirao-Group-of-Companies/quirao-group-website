{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "lint": {
      "cache": true
    },
    "check": {
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate-types": {
      "outputs": ["apps/cms/src/types/strapi-components.ts"]
    }
  }
}
